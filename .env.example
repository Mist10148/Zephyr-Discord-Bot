# ─────────────────────────────────────────────────────────────────────────────
# Zephyr bot configuration template.
# Copy this file to `.env` and fill in your own credentials.
#     cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Discord bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=your-discord-bot-token

# OpenWeatherMap API key (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your-openweathermap-api-key

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Spotify application credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ─── Optional overrides (sensible defaults applied if left blank) ───

# Absolute path to ffmpeg.exe. Leave blank to auto-detect the bundled ffmpeg/ folder.
FFMPEG_PATH=

# URL shown by the /use command (web app link)
WEB_APP_URL=https://severely-musical-mollusk.ngrok-free.app/

# Flask website host/port
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
